---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import { projectsData } from "../../data/projects-data";

// 1. Generate a new path for every collection entry
export async function getStaticPaths() {
  const projects = await getCollection("projects");
  return projects.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

// 2. Get the entry for the current page
const { entry } = Astro.props;
const { Content } = await entry.render();

const projectData = projectsData.find(
  (p) => 
    p.slug === entry.slug || 
    p.title.en.toLowerCase().replace(/\s+/g, "-") === entry.slug
);
const githubLink = projectData?.link;
---

<Layout title={entry.data.title} description={entry.data.description}>
  <main id="main-content">
    <section class="projects border-top">
      <div class="container">
        <div class="filter-wrapper">
          {/* Back Button */}
          <a
            href="/#projects"
            class="back-btn mono"
          >
            $ cd ../
          </a>
          
          <div class="project-header fade-in" style="margin-top: 1.5rem;">
            <p class="mono greeting" style="opacity: 0.7; margin-bottom: 0.5rem; font-size: 0.9rem;">$ cat {entry.slug}.md</p>
            <h1 class="mono" style="font-size: clamp(2rem, 5vw, 4rem); margin-bottom: 1rem; letter-spacing: -0.02em;">
              {entry.data.title}<span class="blink">_</span>
            </h1>
            {entry.data.description && (
              <p class="subtitle mono" style="font-size: 1.25rem; opacity: 0.8; margin-bottom: 1rem;">
                {entry.data.description}
              </p>
            )}

            {githubLink && (
              <div class="mono" style="margin-bottom: 2rem; font-size: 0.95rem; opacity: 0.9;">
                <span style="opacity: 0.7;">$ git clone</span> 
                <a 
                  href={githubLink} 
                  target="_blank" 
                  rel="noopener" 
                  style="margin-left: 0.5rem; text-decoration: underline; color: var(--text);"
                >
                  {githubLink}
                </a>
              </div>
            )}
          </div>

          <article class="project-details mono">
            <Content />
          </article>
        </div>
      </div>
    </section>
  </main>
</Layout>

<style is:global>
  /* Terminal style for Markdown content */
  a.back-btn {
    display: inline-block;
    margin-bottom: 2rem;
    padding: 0.5rem 1rem;
    font-size: 1.1rem;
    font-weight: bold;
    color: var(--text) !important;
    border: 2px solid var(--text) !important;
    text-decoration: none !important;
    transition: all 0.2s;
    opacity: 0.9;
    border-radius: 4px;
  }
  
  a.back-btn:hover {
    background: var(--text) !important;
    color: var(--bg) !important;
    opacity: 1 !important;
  }

  .project-header .blink {
    animation: blink 1s infinite;
  }
  @keyframes blink {
    0%, 50% { opacity: 1; }
    51%, 100% { opacity: 0; }
  }

  .project-details {
    margin-top: 2rem;
  }
  
  .project-details h1,
  .project-details h2,
  .project-details h3,
  .project-details h4,
  .project-details h5,
  .project-details h6 {
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    color: var(--text);
  }
  
  .project-details h2::before,
  .project-details h3::before {
    content: "$ ";
    opacity: 0.7;
    font-weight: normal;
  }

  .project-details p {
    margin-bottom: 1.25rem;
    opacity: 0.9;
  }
  
  .project-details ul {
    list-style-type: none;
    padding-left: 0;
    margin-bottom: 1.5rem;
  }
  
  .project-details li {
    position: relative;
    padding-left: 1.5rem;
    margin-bottom: 0.5rem;
    opacity: 0.9;
  }
  
  .project-details li::before {
    content: ">";
    position: absolute;
    left: 0;
    opacity: 0.7;
  }
  
  .project-details a {
    color: var(--text);
    border-bottom: 1px solid var(--text);
    text-decoration: none;
    transition: opacity 0.2s;
  }
  
  .project-details a:hover {
    opacity: 0.6;
  }
  
  .project-details img {
    max-width: 100%;
    height: auto;
    border: 1px solid var(--text); /* matches featured border */
    margin: 2rem 0;
  }
  
  .project-details strong {
    font-weight: bold;
  }
  
  .project-details code {
    background: transparent;
    border: 1px solid var(--border);
    padding: 0.1rem 0.3rem;
    font-size: 0.9em;
  }
  
  .project-details pre code {
    border: none;
    padding: 0;
  }
  
  .project-details pre {
    border: 1px solid var(--border);
    padding: 1rem;
    overflow-x: auto;
    margin: 1.5rem 0;
    background: transparent;
  }
</style>
